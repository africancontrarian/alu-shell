#!/usr/bin/env bash
# check 4, 9, and 17 while counting to 20

count=1
while (( count<=20 )); do
    echo "$count"
    case "$count" in
	4)
	    echo "bad luck from China"
	    ;;
	
	9)
	    echo "bad luck from Japan"
	    ;;

	17)
	    echo "bad luck from Italy"
	    ;;
    esac

    (( count++ ))
done

    
